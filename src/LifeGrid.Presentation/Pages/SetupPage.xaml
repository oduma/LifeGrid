<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:LifeGrid.Presentation.Controls"
    x:Class="LifeGrid.Presentation.Pages.CreateGoalPage"
    Title="Create Goal"
    BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16" Spacing="16" VerticalOptions="Center">

                <!-- ════════════════════════════════════════════════════ -->
                <!-- STATE E: Generating habits spinner                   -->
                <!-- ════════════════════════════════════════════════════ -->
                <VerticalStackLayout
                    IsVisible="{Binding IsGeneratingHabits}"
                    Spacing="12"
                    HorizontalOptions="Center">

                    <ActivityIndicator
                        IsRunning="{Binding IsGeneratingHabits}"
                        Color="{StaticResource Primary}"
                        HorizontalOptions="Center" />

                    <Label
                        Text="Crafting your personalized plan..."
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center" />

                </VerticalStackLayout>

                <!-- ════════════════════════════════════════════════════ -->
                <!-- STATE F: Infeasibility message                       -->
                <!-- ════════════════════════════════════════════════════ -->
                <VerticalStackLayout
                    IsVisible="{Binding InfeasibilityReason, Converter={StaticResource StringNotEmpty}}"
                    Spacing="16">

                    <Label
                        Text="Goal Not Feasible"
                        Style="{StaticResource HeadlineStyle}" />

                    <Label
                        Text="{Binding InfeasibilityReason}"
                        TextColor="{StaticResource Error}" />

                    <Button
                        Text="Revise Your Goal"
                        Command="{Binding ReviseGoalCommand}" />

                </VerticalStackLayout>

                <!-- ════════════════════════════════════════════════════ -->
                <!-- STATES A/C/D: Goal entry, validating, refinement     -->
                <!-- Hidden while generating or showing infeasibility     -->
                <!-- ════════════════════════════════════════════════════ -->
                <VerticalStackLayout
                    IsVisible="{Binding IsEntryFlowVisible}"
                    Spacing="16">

                    <!-- STATE D: Refinement questions -->
                    <VerticalStackLayout
                        IsVisible="{Binding IsRefinementActive}"
                        Spacing="16">

                        <Label
                            Text="Your Goal"
                            Style="{StaticResource HeadlineStyle}" />

                        <Label Text="{Binding ValidatedGoalSummary}" />

                        <BoxView
                            HeightRequest="1"
                            Color="{StaticResource Secondary}"
                            Margin="0,4" />

                        <Label Text="A few quick questions to calibrate your plan:" />

                        <VerticalStackLayout
                            BindableLayout.ItemsSource="{Binding RefinementItems}"
                            Spacing="12">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Question}" />
                                        <Entry
                                            Text="{Binding Answer, Mode=TwoWay}"
                                            Placeholder="Your answer..." />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <Button
                            Text="Confirm &amp; Initialize"
                            Command="{Binding ConfirmAndInitializeCommand}"
                            Margin="0,8,0,0" />

                    </VerticalStackLayout>

                    <!-- STATE A/C: Goal entry form -->
                    <VerticalStackLayout
                        IsVisible="{Binding IsRefinementActive, Converter={StaticResource InverseBool}}"
                        Spacing="16">

                        <!-- STATE C: Validating spinner -->
                        <VerticalStackLayout
                            IsVisible="{Binding IsValidating}"
                            Spacing="12"
                            HorizontalOptions="Center">

                            <ActivityIndicator
                                IsRunning="{Binding IsValidating}"
                                Color="{StaticResource Primary}"
                                HorizontalOptions="Center" />

                            <Label
                                Text="Analyzing your goal..."
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Center" />

                        </VerticalStackLayout>

                        <!-- STATE A: Goal entry form (hidden while validating) -->
                        <VerticalStackLayout
                            IsVisible="{Binding IsValidating, Converter={StaticResource InverseBool}}"
                            Spacing="16">

                            <Label
                                Text="Tell us about your goal."
                                Style="{StaticResource HeadlineStyle}" />

                            <Label
                                Text="{Binding ValidationError}"
                                IsVisible="{Binding ValidationError, Converter={StaticResource StringNotEmpty}}"
                                TextColor="{StaticResource Error}" />

                            <Entry
                                Text="{Binding GoalDraft}"
                                Placeholder="e.g. Run a marathon in 6 months" />

                            <Button
                                Text="Next"
                                Command="{Binding CompleteStep1Command}" />

                        </VerticalStackLayout>

                    </VerticalStackLayout>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <controls:AdBannerView Grid.Row="1" />

    </Grid>

</ContentPage>
