<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:LifeGrid.Presentation.Controls"
    x:Class="LifeGrid.Presentation.Pages.SetupPage"
    Title="Profile Setup"
    BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16" Spacing="16" VerticalOptions="Center">

                <!-- ══════════════════════════════════════════════════════ -->
                <!-- STATE A/C/E: Goal entry, loading, or done              -->
                <!-- Visible when NOT in the refinement questions phase     -->
                <!-- ══════════════════════════════════════════════════════ -->
                <VerticalStackLayout
                    IsVisible="{Binding IsRefinementActive, Converter={StaticResource InverseBool}}"
                    Spacing="16">

                    <!-- State E: Execution verified — completion message -->
                    <Label
                        IsVisible="{Binding IsExecutionVerified}"
                        Text="Goal Refined and Stored. Ready for Phase 6 Habit Generation."
                        TextColor="{StaticResource Primary}"
                        Style="{StaticResource HeadlineStyle}" />

                    <!-- State A/C: Only shown when not yet verified -->
                    <VerticalStackLayout
                        IsVisible="{Binding IsExecutionVerified, Converter={StaticResource InverseBool}}"
                        Spacing="16">

                        <!-- State C: Validating spinner -->
                        <VerticalStackLayout
                            IsVisible="{Binding IsValidating}"
                            Spacing="12"
                            HorizontalOptions="Center">

                            <ActivityIndicator
                                IsRunning="{Binding IsValidating}"
                                Color="{StaticResource Primary}"
                                HorizontalOptions="Center" />

                            <Label
                                Text="Analyzing your goal..."
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Center" />

                        </VerticalStackLayout>

                        <!-- State A: Goal entry form (hidden while validating) -->
                        <VerticalStackLayout
                            IsVisible="{Binding IsValidating, Converter={StaticResource InverseBool}}"
                            Spacing="16">

                            <Label
                                Text="Tell us about your goal."
                                Style="{StaticResource HeadlineStyle}" />

                            <!-- Inline retry prompt from Gemini (shown after invalid input) -->
                            <Label
                                Text="{Binding ValidationError}"
                                IsVisible="{Binding ValidationError, Converter={StaticResource StringNotEmpty}}"
                                TextColor="{StaticResource Error}" />

                            <Entry
                                Text="{Binding GoalDraft}"
                                Placeholder="e.g. Run a marathon in 6 months" />

                            <Button
                                Text="Next"
                                Command="{Binding CompleteStep1Command}" />

                        </VerticalStackLayout>

                    </VerticalStackLayout>

                </VerticalStackLayout>

                <!-- ══════════════════════════════════════════════════════ -->
                <!-- STATE D: Refinement questions                          -->
                <!-- ══════════════════════════════════════════════════════ -->
                <VerticalStackLayout
                    IsVisible="{Binding IsRefinementActive}"
                    Spacing="16">

                    <Label
                        Text="Your Goal"
                        Style="{StaticResource HeadlineStyle}" />

                    <Label Text="{Binding ValidatedGoalSummary}" />

                    <BoxView
                        HeightRequest="1"
                        Color="{StaticResource Secondary}"
                        Margin="0,4" />

                    <Label Text="A few quick questions to calibrate your plan:" />

                    <!-- Dynamic Q&A pairs from Gemini prompt2 -->
                    <VerticalStackLayout
                        BindableLayout.ItemsSource="{Binding RefinementItems}"
                        Spacing="12">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Question}" />
                                    <Entry
                                        Text="{Binding Answer, Mode=TwoWay}"
                                        Placeholder="Your answer..." />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <Button
                        Text="Confirm &amp; Initialize"
                        Command="{Binding ConfirmAndInitializeCommand}"
                        Margin="0,8,0,0" />

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <controls:AdBannerView Grid.Row="1" />

    </Grid>

</ContentPage>
