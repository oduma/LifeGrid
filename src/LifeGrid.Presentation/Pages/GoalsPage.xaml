<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="clr-namespace:LifeGrid.Presentation.Behaviors"
    xmlns:controls="clr-namespace:LifeGrid.Presentation.Controls"
    xmlns:converters="clr-namespace:LifeGrid.Presentation.Converters"
    xmlns:vm="clr-namespace:LifeGrid.Presentation.ViewModels"
    x:Class="LifeGrid.Presentation.Pages.GoalsPage"
    x:Name="Root"
    Title="Goals"
    BackgroundColor="{StaticResource Background}">

    <ContentPage.Resources>
        <converters:StatusToColorConverter   x:Key="StatusToColorConverter" />
        <converters:StatusIsActiveConverter  x:Key="StatusIsActiveConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0" RowDefinitions="Auto,*,Auto">

            <!-- Vice Survey banner — collapses once survey is completed -->
            <Border
                Grid.Row="0"
                IsVisible="{Binding IsViceSurveyBannerVisible}"
                Margin="16,8,16,0"
                Padding="12"
                BackgroundColor="{StaticResource Secondary}"
                StrokeShape="RoundRectangle 2"
                StrokeThickness="1"
                Stroke="{StaticResource Error}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding LaunchViceSurveyCommand}" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*">
                    <Label
                        Grid.Column="0"
                        Text="&#xe002;"
                        FontFamily="MaterialSymbolsRounded"
                        FontSize="20"
                        TextColor="{StaticResource OnSecondary}"
                        VerticalOptions="Center"
                        Margin="0,0,8,0" />
                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label
                            Text="DETECT HIDDEN VICES"
                            FontFamily="{StaticResource FontShareTechMono}"
                            FontSize="13"
                            FontAttributes="Bold"
                            TextColor="{StaticResource OnSecondary}" />
                        <Label
                            Text="Complete the bad habits survey to earn 1 Bonus Shield"
                            FontFamily="{StaticResource FontShareTechMono}"
                            FontSize="10"
                            TextColor="{StaticResource OnSecondary}"
                            Opacity="0.7" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <CollectionView
                Grid.Row="1"
                ItemsSource="{Binding Goals}">

                <CollectionView.EmptyView>
                    <Label
                        Text="No goals yet"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        HorizontalTextAlignment="Center" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:GoalSummaryItem">

                        <!-- Swipe wrapper: disabled in MultiSelect mode -->
                        <SwipeView IsEnabled="{Binding Source={x:Reference Root}, Path=BindingContext.IsAddGoalVisible}">

                            <!-- Long press is attached here (outermost Android view) so SwipeView's
                                 touch handling cannot intercept before the LongClick listener fires. -->
                            <SwipeView.Behaviors>
                                <behaviors:LongPressBehavior
                                    Command="{Binding Source={x:Reference Root}, Path=BindingContext.EnterMultiSelectCommand}"
                                    CommandParameter="{Binding .}" />
                            </SwipeView.Behaviors>

                            <SwipeView.LeftItems>
                                <SwipeItems Mode="Execute">
                                    <SwipeItem
                                        Text="ABANDON"
                                        BackgroundColor="#FF1B77"
                                        Command="{Binding BindingContext.AbandonGoalSwipeCommand, Source={x:Reference Root}}"
                                        CommandParameter="{Binding GoalId}" />
                                </SwipeItems>
                            </SwipeView.LeftItems>

                            <SwipeView.RightItems>
                                <SwipeItems Mode="Execute">
                                    <SwipeItem
                                        Text="EXTEND"
                                        BackgroundColor="#a20ba0"
                                        Command="{Binding BindingContext.ExtendScheduleSwipeCommand, Source={x:Reference Root}}"
                                        CommandParameter="{Binding GoalId}" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                        <!-- Card container: Surface bg, 2px radius, subtle border -->
                        <Border
                            Margin="16,8"
                            Padding="16"
                            BackgroundColor="{StaticResource Surface}"
                            StrokeShape="RoundRectangle 2"
                            StrokeThickness="1"
                            Stroke="{StaticResource SurfaceBrush}">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference Root}, Path=BindingContext.NavigateToGoalTimelineCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="8">

                                <!-- Zone A: AmbientTag (left) | Status badge (centre) | Checkbox (right) -->
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <Label
                                        Grid.Column="0"
                                        Text="{Binding AmbientTag}"
                                        FontFamily="{StaticResource FontDMMono}"
                                        FontSize="12"
                                        TextColor="{StaticResource OnSurface}"
                                        Opacity="0.6"
                                        VerticalOptions="Center" />
                                    <Border
                                        Grid.Column="1"
                                        Padding="6,2"
                                        StrokeShape="RoundRectangle 2"
                                        StrokeThickness="1"
                                        Stroke="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                        <Label
                                            Text="{Binding Status}"
                                            FontFamily="{StaticResource FontShareTechMono}"
                                            FontSize="11"
                                            TextColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}" />
                                    </Border>
                                    <!-- Selection checkbox — visible only when IsSelected -->
                                    <Label
                                        Grid.Column="2"
                                        Text="&#xE834;"
                                        FontFamily="MaterialSymbolsRounded"
                                        FontSize="22"
                                        TextColor="{StaticResource Primary}"
                                        IsVisible="{Binding IsSelected}"
                                        VerticalOptions="Center"
                                        Margin="8,0,0,0" />
                                </Grid>

                                <!-- Zone B: Description — dominant DM Mono headline -->
                                <Label
                                    Text="{Binding Description}"
                                    FontFamily="{StaticResource FontDMMono}"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource OnSurface}"
                                    LineHeight="1.3" />

                                <!-- Zone C: Metric columns (DURATION | DEADLINE | TOTAL WKS) -->
                                <Grid ColumnDefinitions="*,*,*" Margin="0,8,0,0">

                                    <!-- Col 1: Duration — left anchor -->
                                    <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Start">
                                        <Label
                                            Text="DURATION"
                                            FontFamily="{StaticResource FontShareTechMono}"
                                            FontSize="10"
                                            TextColor="{StaticResource OnSurface}"
                                            Opacity="0.5" />
                                        <Label
                                            Text="{Binding Duration}"
                                            FontFamily="{StaticResource FontShareTechMono}"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource OnSurface}" />
                                    </VerticalStackLayout>

                                    <!-- Col 2: Deadline — centred -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                                        <Label
                                            Text="DEADLINE"
                                            FontFamily="{StaticResource FontShareTechMono}"
                                            FontSize="10"
                                            TextColor="{StaticResource OnSurface}"
                                            Opacity="0.5"
                                            HorizontalTextAlignment="Center" />
                                        <Label
                                            Text="{Binding DeadlineDate, StringFormat='{0:dd MMM yyyy}'}"
                                            FontFamily="{StaticResource FontShareTechMono}"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource OnSurface}"
                                            HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>

                                    <!-- Col 3: Total Weeks — right anchor, Primary accent -->
                                    <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="End">
                                        <Label
                                            Text="TOTAL WKS"
                                            FontFamily="{StaticResource FontShareTechMono}"
                                            FontSize="10"
                                            TextColor="{StaticResource OnSurface}"
                                            Opacity="0.5"
                                            HorizontalTextAlignment="End" />
                                        <Label
                                            Text="{Binding TotalWeeks}"
                                            FontFamily="{StaticResource FontShareTechMono}"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource Primary}"
                                            HorizontalTextAlignment="End" />
                                    </VerticalStackLayout>

                                </Grid>

                            </VerticalStackLayout>
                        </Border>

                        </SwipeView>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <!-- Bottom action row: toggles between Standard and MultiSelect modes -->
            <Grid Grid.Row="2" Margin="16,8">

                <!-- Standard mode: Add Goal -->
                <Button
                    Text="Add Goal"
                    IsVisible="{Binding IsAddGoalVisible}"
                    Command="{Binding AddGoalCommand}" />

                <!-- MultiSelect mode: View Filtered Timeline + Cancel -->
                <VerticalStackLayout
                    IsVisible="{Binding IsMultiSelectMode}"
                    Spacing="8">
                    <Button
                        Text="View Filtered Timeline"
                        IsEnabled="{Binding IsViewFilteredTimelineVisible}"
                        Command="{Binding ViewFilteredTimelineCommand}" />
                    <Button
                        Text="Cancel"
                        Command="{Binding ExitMultiSelectCommand}" />
                </VerticalStackLayout>

            </Grid>

        </Grid>

        <controls:AdBannerView Grid.Row="1" />

    </Grid>

</ContentPage>
