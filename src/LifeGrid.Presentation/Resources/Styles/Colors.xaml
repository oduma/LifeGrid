<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- LifeGrid Design Tokens — Clean Pixel Neon / M3 Light Mode -->
    <Color x:Key="Primary">#35f8db</Color>
    <Color x:Key="OnPrimary">#58585a</Color>
    <Color x:Key="Secondary">#e5cde1</Color>
    <Color x:Key="OnSecondary">#a20ba0</Color>
    <Color x:Key="Background">#fbfbfe</Color>
    <Color x:Key="Surface">#ffffff</Color>
    <Color x:Key="OnSurface">#58585a</Color>
    <Color x:Key="Error">#FF1B77</Color>

    <!-- Brush counterparts for Shell/Border properties that require Brush -->
    <SolidColorBrush x:Key="PrimaryBrush"    Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="SecondaryBrush"  Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}" />
    <SolidColorBrush x:Key="SurfaceBrush"    Color="{StaticResource Surface}" />
    <SolidColorBrush x:Key="OnSurfaceBrush"  Color="{StaticResource OnSurface}" />
    <SolidColorBrush x:Key="ErrorBrush"      Color="{StaticResource Error}" />

    <!-- Scalar constants -->
    <x:Double x:Key="GlobalCornerRadius">2</x:Double>
    <x:Double x:Key="ScreenMargin">16</x:Double>
    <x:Double x:Key="ItemSpacing">8</x:Double>
    <x:Double x:Key="SectionSpacing">16</x:Double>
    <x:Double x:Key="HudHeight">85</x:Double>
    <x:Double x:Key="AdBannerHeight">50</x:Double>
    <x:Double x:Key="TabBarHeight">80</x:Double>

</ResourceDictionary>
