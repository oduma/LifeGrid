<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Font aliases -->
    <x:String x:Key="FontDMMono">DMMono-Regular</x:String>
    <x:String x:Key="FontDMMonoMedium">DMMono-Medium</x:String>
    <x:String x:Key="FontDMMonoItalic">DMMono-Italic</x:String>
    <x:String x:Key="FontShareTechMono">ShareTechMono-Regular</x:String>
    <x:String x:Key="FontMaterialSymbols">MaterialSymbolsRounded</x:String>

    <!-- Implicit Label: Share Tech Mono body default -->
    <Style TargetType="Label">
        <Setter Property="TextColor"       Value="{StaticResource OnSurface}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily"      Value="{StaticResource FontShareTechMono}" />
        <Setter Property="FontSize"        Value="14" />
    </Style>

    <!-- Headline: DM Mono large display text -->
    <Style TargetType="Label" x:Key="HeadlineStyle">
        <Setter Property="FontFamily"           Value="{StaticResource FontDMMono}" />
        <Setter Property="FontSize"             Value="28" />
        <Setter Property="TextColor"            Value="{StaticResource OnSurface}" />
        <Setter Property="HorizontalOptions"    Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- Icon: Material Symbols Rounded glyph rendered as Label -->
    <Style TargetType="Label" x:Key="IconStyle">
        <Setter Property="FontFamily" Value="{StaticResource FontMaterialSymbols}" />
        <Setter Property="FontSize"   Value="24" />
        <Setter Property="TextColor"  Value="{StaticResource OnSurface}" />
    </Style>

    <!-- Button: Share Tech Mono, Primary background, 2px radius -->
    <Style TargetType="Button">
        <Setter Property="FontFamily"        Value="{StaticResource FontShareTechMono}" />
        <Setter Property="FontSize"          Value="14" />
        <Setter Property="TextColor"         Value="{StaticResource OnPrimary}" />
        <Setter Property="BackgroundColor"   Value="{StaticResource Primary}" />
        <Setter Property="CornerRadius"      Value="2" />
        <Setter Property="BorderWidth"       Value="0" />
        <Setter Property="Padding"           Value="14,10" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest"  Value="44" />
    </Style>

    <!-- Entry: Share Tech Mono, OnSurface text -->
    <Style TargetType="Entry">
        <Setter Property="FontFamily"      Value="{StaticResource FontShareTechMono}" />
        <Setter Property="FontSize"        Value="14" />
        <Setter Property="TextColor"       Value="{StaticResource OnSurface}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="PlaceholderColor" Value="{StaticResource OnSurface}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest"  Value="44" />
    </Style>

    <!-- Border: 2px radius, Surface stroke -->
    <Style TargetType="Border">
        <Setter Property="Stroke"          Value="{StaticResource SurfaceBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 2" />
    </Style>

    <!-- Page: Background token -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding"          Value="0" />
        <Setter Property="BackgroundColor"  Value="{StaticResource Background}" />
    </Style>

    <!-- Shell: LifeGrid tab bar tokens -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor"       Value="{StaticResource Surface}" />
        <Setter Property="Shell.ForegroundColor"       Value="{StaticResource OnSurface}" />
        <Setter Property="Shell.TitleColor"            Value="{StaticResource OnSurface}" />
        <Setter Property="Shell.NavBarHasShadow"       Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.TabBarTitleColor"      Value="{StaticResource Primary}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource OnSurface}" />
    </Style>

</ResourceDictionary>
